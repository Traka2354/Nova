# ============================================================
#  PRESET 1: ZASTITA 12X NALOGA (kill-switch)
#  Kopiraj u .env u zasebnom folderu/instanci i popuni nalog.
#  Bot NE otvara nove trejdove - samo cuva nalog od probijanja
#  brokerovih ~10% (zatvori sve + pauza na -6%).
# ============================================================

ACCOUNT_MODE=live
LIVE_MT5_LOGIN=
LIVE_MT5_PASSWORD=
LIVE_MT5_SERVER=
LIVE_MT5_PATH=

SYMBOL=XAUUSD.f

# pura zastita - bez AI ulazaka i bez copiera
AI_ENABLED=false
COPY_ENABLED=false

# DD baza = POJACANI balans naloga (npr. ~23712 sa tvog snimka)
ACCOUNT_BASELINE=23712
MAX_TOTAL_DRAWDOWN_PCT=0.06
DRAWDOWN_TRAILING=false
DRAWDOWN_FLATTEN=true

# kill-switch reaguje brzo
POLL_INTERVAL_SEC=15

# odvojen folder za log/stanje (da se ne sudara sa drugom instancom)
STATE_DIR=logs_12x
