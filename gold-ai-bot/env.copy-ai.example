# ============================================================
#  PRESET 2: KOPIJA SIGNALA + AI na DRUGOM nalogu
#  Kopiraj u .env u zasebnom folderu/instanci.
#  - kopira pozicije sa MASTER (tvoj 12X) na OVAJ nalog,
#  - i pusta AI mozak da trguje NEZAVISNO (makro stil).
#  Prvo testiraj na DEMO nalogu!
# ============================================================

ACCOUNT_MODE=demo
DEMO_MT5_LOGIN=
DEMO_MT5_PASSWORD=
DEMO_MT5_SERVER=
DEMO_MT5_PATH=

SYMBOL=XAUUSD.f

# --- AI mozak (nezavisni makro trejdovi) ---
AI_ENABLED=true
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-7
AI_WEB_RESEARCH=true
MIN_CONFIDENCE=0.65

# --- Copy trading: MASTER = tvoj 12X nalog (investor/read-only login) ---
COPY_ENABLED=true
COPY_MASTER_LOGIN=
COPY_MASTER_PASSWORD=
COPY_MASTER_SERVER=
COPY_MASTER_PATH=
COPY_LOT_MULTIPLIER=1.0

# DD baza ovog naloga (0 = auto pri prvom pokretanju)
ACCOUNT_BASELINE=0
MAX_TOTAL_DRAWDOWN_PCT=0.06

# odvojen folder za log/stanje
STATE_DIR=logs_copy
